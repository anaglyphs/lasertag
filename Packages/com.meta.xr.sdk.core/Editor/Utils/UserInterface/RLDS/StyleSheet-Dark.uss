/*
 * RLDS (Reality Labs Design System) Dark Mode Stylesheet
 * Based on RLDS Desktop design system
 */

/* ========================================
   COLOR VARIABLES (Dark Mode)
   ======================================== */

:root {
    /* Surface colors */
    --rlds-surface-primary-background: rgb(39, 39, 39); /* #272727 */
    --rlds-surface-secondary-background: rgb(60, 60, 60); /* #3C3C3C */

    /* Divider colors */
    --rlds-divider-primary: rgb(39, 39, 39); /* #272727 */
    --rlds-divider-secondary: rgba(255, 255, 255, 0.05); /* #FFFFFF0D */
    --rlds-border-divider: rgba(0, 0, 0, 0.2);

    /* Navigation item colors */
    --rlds-nav-item-background-default: rgba(255, 255, 255, 0);
    --rlds-nav-item-background-hover: rgba(255, 255, 255, 0.05);
    --rlds-nav-item-background-sub-selected: rgba(255, 255, 255, 0.1);
    --rlds-nav-item-background-selected: rgba(255, 255, 255, 0.2);

    /* Button backgrounds */
    --rlds-button-primary-background-default: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-button-primary-background-hover: rgb(217, 217, 217); /* #D9D9D9 */
    --rlds-button-primary-background-pressed: rgb(192, 192, 192); /* #C0C0C0 */
    --rlds-button-secondary-background-default: rgba(255, 255, 255, 0.05); /* #FFFFFF0D */
    --rlds-button-secondary-background-hover: rgba(255, 255, 255, 0.1); /* #FFFFFF1A */
    --rlds-button-secondary-background-pressed: rgba(255, 255, 255, 0.2); /* #FFFFFF33 */
    --rlds-button-tertiary-background-default: rgba(255, 255, 255, 0); /* #FFFFFF00 */
    --rlds-button-tertiary-background-hover: rgba(255, 255, 255, 0.1); /* #FFFFFF1A */
    --rlds-button-tertiary-background-pressed: rgba(255, 255, 255, 0.2); /* #FFFFFF33 */
    --rlds-button-onmedia-background-default: rgba(255, 255, 255, 0); /* #FFFFFF00 */
    --rlds-button-onmedia-background-hover: rgba(255, 255, 255, 0.1); /* #FFFFFF1A */
    --rlds-button-onmedia-background-pressed: rgba(255, 255, 255, 0.2); /* #FFFFFF33 */
    --rlds-button-deselected-background-default: rgba(255, 255, 255, 0.05); /* #FFFFFF0D */
    --rlds-button-deselected-background-hover: rgba(255, 255, 255, 0.1); /* #FFFFFF1A */
    --rlds-button-deselected-background-pressed: rgba(255, 255, 255, 0.2); /* #FFFFFF33 */
    --rlds-button-selected-background-default: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-button-selected-background-hover: rgb(242, 242, 242); /* #F2F2F2 */
    --rlds-button-selected-background-pressed: rgb(217, 217, 217); /* #D9D9D9 */
    --rlds-button-disable-background: rgb(90, 90, 90); /* #5A5A5A */

    /* Border colors */
    --rlds-border-color: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-border-color-dark: rgb(48, 48, 48); /* #303030 */

    /* Icon UI colors */
    --rlds-icon-ui-primary: rgb(39, 39, 39); /* #272727 */
    --rlds-icon-ui-secondary: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-icon-ui-tertiary: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-icon-ui-disabled: rgb(142, 142, 142); /* #8E8E8E */
    --rlds-icon-ui-onmedia: rgb(242, 242, 242); /* #F2F2F2 */
    --rlds-icon-ui-selected: rgb(39, 39, 39); /* #272727 */
    --rlds-icon-ui-deselected: rgb(255, 255, 255); /* #FFFFFF */

    /* Icon semantic colors */
    --rlds-icon-positive: rgb(42, 209, 22); /* #2AD116 */
    --rlds-icon-negative: rgb(247, 129, 140); /* #F7818C */
    --rlds-icon-warning: rgb(252, 148, 53); /* #FC9435 */
    --rlds-icon-notification: rgb(100, 181, 255); /* #64B5FF */
    --rlds-icon-privacy: rgb(156, 148, 248); /* #9C94F8 */

    /* Icon general colors */
    --rlds-icon-primary: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-icon-secondary: rgba(255, 255, 255, 0.7); /* #FFFFFFB3 */
    --rlds-icon-onmedia: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-icon-secondary-onmedia: rgba(255, 255, 255, 0.7); /* #FFFFFFB3 */
    --rlds-icon-disabled: rgba(255, 255, 255, 0.3); /* #FFFFFF4D */
    --rlds-icon-placeholder: rgba(255, 255, 255, 0.3); /* #FFFFFF4D */
    --rlds-icon-object-instance: rgb(192, 223, 255); /* #C0DFFF */

    /* Text UI colors */
    --rlds-text-ui-primary: rgb(39, 39, 39); /* #272727 */
    --rlds-text-ui-secondary: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-text-ui-tertiary: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-text-ui-onmedia: rgb(242, 242, 242); /* #F2F2F2 */
    --rlds-text-ui-disabled: rgb(142, 142, 142); /* #8E8E8E */
    --rlds-text-ui-deselected: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-text-ui-selected: rgb(39, 39, 39); /* #272727 */

    /* Text general colors */
    --rlds-text-primary: rgba(255, 255, 255, 0.75); /* #FFFFFF */
    --rlds-text-secondary: rgba(255, 255, 255, 0.7); /* #FFFFFFB3 */
    --rlds-text-placeholder: rgba(255, 255, 255, 0.7); /* #FFFFFFB3 */
    --rlds-text-disabled: rgba(255, 255, 255, 0.3); /* #FFFFFF4D */
    --rlds-text-primary-onmedia: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-text-secondary-onmedia: rgba(255, 255, 255, 0.7); /* #FFFFFFB3 */

    /* Text semantic colors */
    --rlds-text-warning: rgb(252, 148, 53); /* #FC9435 */
    --rlds-text-link: rgb(100, 181, 255); /* #64B5FF */
    --rlds-text-positive: rgb(42, 209, 22); /* #2AD116 */
    --rlds-text-negative: rgb(247, 129, 140); /* #F7818C */
    --rlds-text-object-instance: rgb(192, 223, 255); /* #C0DFFF */

    /* Viewport colors */
    --rlds-viewport-canvas: rgb(61, 61, 61); /* #3D3D3D */

    /* Badge colors */
    --rlds-badge-positive: rgb(42, 209, 22); /* #2AD116 */
    --rlds-badge-negative: rgb(247, 129, 140); /* #F7818C */
    --rlds-badge-warning: rgb(252, 148, 53); /* #FC9435 */
    --rlds-badge-disabled: rgb(142, 142, 142); /* #8E8E8E */
    --rlds-badge-default: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-badge-privacy: rgb(156, 148, 248); /* #9C94F8 */

    /* Input colors */
    --rlds-input-default: rgb(90, 90, 90); /* #5A5A5A */
    --rlds-input-disabled: rgb(90, 90, 90); /* #5A5A5A */
    --rlds-input-hover: rgba(255, 255, 255, 0.1); /* #FFFFFF1A */
    --rlds-input-pressed: rgba(255, 255, 255, 0.2); /* #FFFFFF33 */
    --rlds-input-selected: rgb(255, 255, 255); /* #FFFFFF */

    /* Toggle colors */
    --rlds-toggle-thumb-default: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-toggle-thumb-hover: rgb(255, 255, 255); /* #FFFFFF */
    --rlds-toggle-thumb-pressed: rgb(217, 217, 217); /* #D9D9D9 */
    --rlds-toggle-thumb-disabled: rgb(142, 142, 142); /* #8E8E8E */
    --rlds-toggle-thumb-selected: rgb(255, 255, 255); /* #FFFFFF */

    /* Slider colors */
    --rlds-slider-track-default: rgba(0, 0, 0, 0.1); /* #0000001A */
    --rlds-slider-track-disabled: rgb(90, 90, 90); /* #5A5A5A */
    --rlds-slider-track-selected: rgb(255, 255, 255); /* #FFFFFF */

    /* Progress bar colors */
    --rlds-progress-bar-empty: rgba(0, 0, 0, 0.25); /* #00000040 */
    --rlds-progress-bar-error: rgb(247, 129, 140); /* #F7818C */
    --rlds-progress-bar-filled: rgb(42, 209, 22); /* #2AD116 */

    /* Progress ring colors */
    --rlds-progress-ring-foreground-default: rgb(100, 181, 255); /* #64B5FF */
    --rlds-progress-ring-foreground-accent: rgb(42, 209, 22); /* #2AD116 */
    --rlds-progress-ring-foreground-disabled: rgb(142, 142, 142); /* #8E8E8E */
    --rlds-progress-ring-foreground-dark: rgb(39, 39, 39); /* #272727 */
    --rlds-progress-ring-foreground-light: rgb(255, 255, 255); /* #FFFFFF */

    /* Font sizes */
    --rlds-font-size-4xl: 56px;
    --rlds-font-size-3xl: 32px;
    --rlds-font-size-2xl: 24px;
    --rlds-font-size-xl: 20px;
    --rlds-font-size-lg: 16px;
    --rlds-font-size-md: 14px;
    --rlds-font-size-sm: 12px;
    --rlds-font-size-xs: 11px;
    --rlds-font-size-2xs: 10px;

    /* Font weights */
    --rlds-font-weight-bold: bold;
    --rlds-font-weight-semibold: 600;
    --rlds-font-weight-medium: 500;
    --rlds-font-weight-regular: normal;

    /* Line heights */
    --rlds-line-height-8xl: 60px;
    --rlds-line-height-7xl: 52px;
    --rlds-line-height-6xl: 44px;
    --rlds-line-height-5xl: 40px;
    --rlds-line-height-4xl: 36px;
    --rlds-line-height-3xl: 28px;
    --rlds-line-height-2xl: 26px;
    --rlds-line-height-xl: 24px;
    --rlds-line-height-lg: 20px;
    --rlds-line-height-md: 18px;
    --rlds-line-height-sm: 16px;
    --rlds-line-height-xs: 13px;

    /* Letter spacing */
    --rlds-letter-spacing-title: -1px;
    --rlds-letter-spacing-heading: -0.5px;
    --rlds-letter-spacing-eyebrow: 0.3px;
    --rlds-letter-spacing-normal: 0px;

    /* Spacing */
    --rlds-spacing-none: 0px;
    --rlds-spacing-4xs: 2px;
    --rlds-spacing-3xs: 4px;
    --rlds-spacing-2xs: 6px;
    --rlds-spacing-xs: 8px;
    --rlds-spacing-sm: 12px;
    --rlds-spacing-md: 16px;
    --rlds-spacing-2x-md: 32px;
    --rlds-spacing-lg: 20px;
    --rlds-spacing-xl: 24px;
    --rlds-spacing-2xl: 38px;
    --rlds-spacing-3xl: 40px;
    --rlds-spacing-4xl: 48px;
    --rlds-spacing-5xl: 64px;

    /* Border radius */
    --rlds-radius-none: 0px;
    --rlds-radius-xs: 4px;
    --rlds-radius-sm: 8px;
    --rlds-radius-md: 14px;
    --rlds-radius-lg: 24px;
    --rlds-radius-xl: 32px;
    --rlds-radius-full: 1000px;

    /* Icon sizes */
    --rlds-icon-size-2xs: 8px;
    --rlds-icon-size-xs: 12px;
     --rlds-icon-size-sm: 16px;
    --rlds-icon-size-md: 18px;
    --rlds-icon-size-lg: 24px;
    --rlds-icon-size-xl: 32px;
    --rlds-icon-size-2xl: 48px;
    --rlds-icon-size-3xl: 72px;

    /* Border width */
    --rlds-border-width: 1px;

    /* Button sizes - Large */
    --rlds-button-large-height: 40px;
    --rlds-button-large-min-width: 120px;
    --rlds-button-large-padding-horizontal: 16px;
    --rlds-button-large-padding-vertical: 10px;

    /* Button sizes - Small */
    --rlds-button-small-height: 32px;
    --rlds-button-small-min-width: 80px;
    --rlds-button-small-padding-horizontal: 12px;
    --rlds-button-small-padding-vertical: 6px;

    /* Button sizes - XSmall */
    --rlds-button-xsmall-height: 24px;
    --rlds-button-xsmall-min-width: 60px;
    --rlds-button-xsmall-padding-horizontal: 8px;
    --rlds-button-xsmall-padding-vertical: 4px;

    /* Shadows - Dark mode */
    --rlds-shadow-beveled: 1px 1px 1px 0px rgba(255, 255, 255, 0.10) inset, -1px -1px 1px 0px rgba(0, 0, 0, 0.10) inset;
    --rlds-shadow-dropshadow: 0px 0px 32px 0px rgba(0, 0, 0, 0.10), 0px 16px 48px 0px rgba(0, 0, 0, 0.20), 1px 1px 1px 0px rgba(255, 255, 255, 0.10) inset, -1px -1px 1px 0px rgba(0, 0, 0, 0.10) inset;
    --rlds-shadow-punched-in: 0px 1px 1px 0px rgba(255, 255, 255, 0.10), 0px 1px 1px 0px rgba(0, 0, 0, 0.10) inset;
}

/* ========================================
   TYPOGRAPHY STYLES
   ======================================== */

.rlds-title {
    font-size: var(--rlds-font-size-4xl);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-title);
    color: var(--rlds-text-primary);
}

.rlds-title-italic {
    font-size: var(--rlds-font-size-4xl);
    -unity-font-style: bold-and-italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-title);
    color: var(--rlds-text-primary);
}

.rlds-heading1 {
    font-size: var(--rlds-font-size-3xl);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-title);
    color: var(--rlds-text-primary);
}

.rlds-heading1-italic {
    font-size: var(--rlds-font-size-3xl);
    -unity-font-style: bold-and-italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-title);
    color: var(--rlds-text-primary);
}

.rlds-heading2 {
    font-size: var(--rlds-font-size-2xl);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-heading);
    color: var(--rlds-text-primary);
}

.rlds-heading2-italic {
    font-size: var(--rlds-font-size-2xl);
    -unity-font-style: bold-and-italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-heading);
    color: var(--rlds-text-primary);
}

.rlds-heading3 {
    font-size: var(--rlds-font-size-xl);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-heading);
    color: var(--rlds-text-primary);
}

.rlds-heading3-italic {
    font-size: var(--rlds-font-size-xl);
    -unity-font-style: bold-and-italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-heading);
    color: var(--rlds-text-primary);
}

.rlds-heading4 {
    font-size: var(--rlds-font-size-lg);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-heading);
    color: var(--rlds-text-primary);
}

.rlds-heading4-italic {
    font-size: var(--rlds-font-size-lg);
    -unity-font-style: bold-and-italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-heading);
    color: var(--rlds-text-primary);
}

.rlds-body1-label {
    font-size: var(--rlds-font-size-md);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-normal);
    color: var(--rlds-text-primary);
}

.rlds-body1-text {
    font-size: var(--rlds-font-size-md);
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-normal);
    color: var(--rlds-text-primary);
}

.rlds-body1-text-italic {
    font-size: var(--rlds-font-size-md);
    -unity-font-style: italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-normal);
    color: var(--rlds-text-primary);
}

.rlds-body1-button {
    font-size: var(--rlds-font-size-md);
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    letter-spacing: var(--rlds-letter-spacing-normal);
    color: var(--rlds-text-primary);
}

.rlds-body2-small-label {
    font-size: var(--rlds-font-size-sm);
    -unity-font-style: bold;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-normal);
    color: var(--rlds-text-secondary);
}

.rlds-body2-small-button {
    font-size: var(--rlds-font-size-sm);
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    letter-spacing: var(--rlds-letter-spacing-normal);
    color: var(--rlds-text-primary);
}

.rlds-body2-supporting-text {
    font-size: var(--rlds-font-size-sm);
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-normal);
    color: var(--rlds-text-secondary);
}

.rlds-body2-supporting-text-italic {
    font-size: var(--rlds-font-size-sm);
    -unity-font-style: italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-normal);
    color: var(--rlds-text-secondary);
}

.rlds-meta {
    font-size: var(--rlds-font-size-xs);
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-normal);
    color: var(--rlds-text-secondary);
}

.rlds-meta-italic {
    font-size: var(--rlds-font-size-xs);
    -unity-font-style: italic;
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-normal);
    color: var(--rlds-text-secondary);
}

.rlds-eyebrow-label {
    font-size: var(--rlds-font-size-xs);
    -unity-text-align: upper-left;
    letter-spacing: var(--rlds-letter-spacing-eyebrow);
    color: var(--rlds-text-primary);
}

/* ========================================
   BUTTON STYLES - PRIMARY
   ======================================== */

.rlds-button-primary {
    height: var(--rlds-button-large-height);
    min-width: var(--rlds-button-large-min-width);
    padding: var(--rlds-button-large-padding-vertical) var(--rlds-button-large-padding-horizontal);
    background-color: var(--rlds-button-primary-background-default);
    color: var(--rlds-text-ui-primary);
    border-radius: var(--rlds-radius-xs);
    font-size: 14px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    border-width: 0;
}

.rlds-button-primary:hover {
    background-color: var(--rlds-button-primary-background-hover);
}

.rlds-button-primary:active {
    background-color: var(--rlds-button-primary-background-pressed);
}

.rlds-button-primary:disabled {
    background-color: var(--rlds-button-disable-background);
    color: var(--rlds-text-ui-disabled);
}

/* ========================================
   BUTTON STYLES - SECONDARY
   ======================================== */

.rlds-button-secondary {
    height: var(--rlds-button-large-height);
    min-width: var(--rlds-button-large-min-width);
    padding: var(--rlds-button-large-padding-vertical) var(--rlds-button-large-padding-horizontal);
    background-color: var(--rlds-button-secondary-background-default);
    color: var(--rlds-text-ui-secondary);
    border-radius: var(--rlds-radius-xs);
    font-size: 14px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    border-width: 0;
}

.rlds-button-secondary:hover {
    background-color: var(--rlds-button-secondary-background-hover);
}

.rlds-button-secondary:active {
    background-color: var(--rlds-button-secondary-background-pressed);
}

.rlds-button-secondary:disabled {
    background-color: var(--rlds-button-disable-background);
    color: var(--rlds-text-ui-disabled);
}

/* ========================================
   BUTTON STYLES - TERTIARY
   ======================================== */

.rlds-button-tertiary {
    height: var(--rlds-button-large-height);
    min-width: var(--rlds-button-large-min-width);
    padding: var(--rlds-button-large-padding-vertical) var(--rlds-button-large-padding-horizontal);
    background-color: var(--rlds-button-tertiary-background-default);
    color: var(--rlds-text-ui-tertiary);
    border-radius: var(--rlds-radius-xs);
    font-size: 14px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    border-width: 0;
}

.rlds-button-tertiary:hover {
    background-color: var(--rlds-button-tertiary-background-hover);
}

.rlds-button-tertiary:active {
    background-color: var(--rlds-button-tertiary-background-pressed);
}

.rlds-button-tertiary:disabled {
    background-color: var(--rlds-button-disable-background);
    color: var(--rlds-text-ui-disabled);
}

/* ========================================
   BUTTON STYLES - ON MEDIA
   ======================================== */

.rlds-button-onmedia {
    height: var(--rlds-button-large-height);
    min-width: var(--rlds-button-large-min-width);
    padding: var(--rlds-button-large-padding-vertical) var(--rlds-button-large-padding-horizontal);
    background-color: var(--rlds-button-onmedia-background-default);
    color: var(--rlds-text-ui-onmedia);
    border-radius: var(--rlds-radius-xs);
    font-size: 14px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    border-width: var(--rlds-border-width);
    border-color: var(--rlds-border-color);
}

.rlds-button-onmedia:hover {
    background-color: var(--rlds-button-onmedia-background-hover);
}

.rlds-button-onmedia:active {
    background-color: var(--rlds-button-onmedia-background-pressed);
}

.rlds-button-onmedia:disabled {
    background-color: var(--rlds-button-disable-background);
    color: var(--rlds-text-ui-disabled);
}

