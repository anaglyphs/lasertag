   ======================================== */

.rlds-button-secondary-xsmall {
    height: var(--rlds-button-xsmall-height);
    min-width: var(--rlds-button-xsmall-min-width);
    padding: var(--rlds-button-xsmall-padding-vertical) var(--rlds-button-xsmall-padding-horizontal);
    background-color: var(--rlds-button-secondary-background-default);
    color: var(--rlds-text-ui-secondary);
    border-radius: var(--rlds-radius-xs);
    font-size: 12px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    border-width: 0;
}

.rlds-button-secondary-xsmall:hover {
    background-color: var(--rlds-button-secondary-background-hover);
}

.rlds-button-secondary-xsmall:active {
    background-color: var(--rlds-button-secondary-background-pressed);
}

.rlds-button-secondary-xsmall:disabled {
    background-color: var(--rlds-button-disable-background);
    color: var(--rlds-text-ui-disabled);
}

/* ========================================
   BUTTON STYLES - XSMALL TERTIARY
   ======================================== */

.rlds-button-tertiary-xsmall {
    height: var(--rlds-button-xsmall-height);
    min-width: var(--rlds-button-xsmall-min-width);
    padding: var(--rlds-button-xsmall-padding-vertical) var(--rlds-button-xsmall-padding-horizontal);
    background-color: var(--rlds-button-tertiary-background-default);
    color: var(--rlds-text-ui-tertiary);
    border-radius: var(--rlds-radius-xs);
    font-size: 12px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    border-width: 0;
}

.rlds-button-tertiary-xsmall:hover {
    background-color: var(--rlds-button-tertiary-background-hover);
}

.rlds-button-tertiary-xsmall:active {
    background-color: var(--rlds-button-tertiary-background-pressed);
}

.rlds-button-tertiary-xsmall:disabled {
    background-color: var(--rlds-button-disable-background);
    color: var(--rlds-text-ui-disabled);
}

/* ========================================
   BUTTON STYLES - XSMALL ON MEDIA
   ======================================== */

.rlds-button-onmedia-xsmall {
    height: var(--rlds-button-xsmall-height);
    min-width: var(--rlds-button-xsmall-min-width);
    padding: var(--rlds-button-xsmall-padding-vertical) var(--rlds-button-xsmall-padding-horizontal);
    background-color: var(--rlds-button-onmedia-background-default);
    color: var(--rlds-text-ui-onmedia);
    border-radius: var(--rlds-radius-xs);
    font-size: 12px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    border-width: var(--rlds-border-width);
    border-color: var(--rlds-border-color);
}

.rlds-button-onmedia-xsmall:hover {
    background-color: var(--rlds-button-onmedia-background-hover);
}

.rlds-button-onmedia-xsmall:active {
    background-color: var(--rlds-button-onmedia-background-pressed);
}

.rlds-button-onmedia-xsmall:disabled {
    background-color: var(--rlds-button-disable-background);
    color: var(--rlds-text-ui-disabled);
}

/* ========================================
   UTILITY CLASSES
   ======================================== */

.rlds-padding-md {
    padding: var(--rlds-spacing-md);
}

.rlds-padding-sm {
    padding: var(--rlds-spacing-sm);
}

.rlds-padding-2x-md {
    padding: var(--rlds-spacing-2x-md);
}

.rlds-padding-top-lg {
    padding-top: var(--rlds-spacing-lg);
}

.rlds-margin-top-sm {
    margin-top: var(--rlds-spacing-sm);
}

.rlds-margin-top-3xs {
    margin-top: var(--rlds-spacing-3xs);
}

.rlds-margin-lg {
    margin: var(--rlds-spacing-lg);
}

.rlds-no-margin {
    margin: 0;
}

.rlds-cursor-link {
    cursor: link;
}

/* ========================================
   FLEXBOX UTILITY CLASSES
   ======================================== */

/* Flex Direction */
.rlds-flex-row {
    flex-direction: row;
}

.rlds-flex-column {
    flex-direction: column;
}

.rlds-flex-row-reverse {
    flex-direction: row-reverse;
}

.rlds-flex-column-reverse {
    flex-direction: column-reverse;
}

/* Justify Content (main axis alignment) */
.rlds-justify-start {
    justify-content: flex-start;
}

.rlds-justify-end {
    justify-content: flex-end;
}

.rlds-justify-center {
    justify-content: center;
}

.rlds-justify-space-between {
    justify-content: space-between;
}

.rlds-justify-space-around {
    justify-content: space-around;
}

/* Align Items (cross axis alignment) */
.rlds-align-start {
    align-items: flex-start;
}

.rlds-align-end {
    align-items: flex-end;
}

.rlds-align-center {
    align-items: center;
}

.rlds-align-stretch {
    align-items: stretch;
}

/* Align Self (override parent's align-items) */
.rlds-self-start {
    align-self: flex-start;
}

.rlds-self-end {
    align-self: flex-end;
}

.rlds-self-center {
    align-self: center;
}

.rlds-self-stretch {
    align-self: stretch;
}

/* Flex Grow & Shrink */
.rlds-flex-grow-0 {
    flex-grow: 0;
}

.rlds-flex-grow-1 {
    flex-grow: 1;
}

.rlds-flex-shrink-0 {
    flex-shrink: 0;
}

.rlds-flex-shrink-1 {
    flex-shrink: 1;
}

/* Flex Wrap */
.rlds-flex-nowrap {
    flex-wrap: nowrap;
}

.rlds-flex-wrap {
    flex-wrap: wrap;
}

.rlds-flex-wrap-reverse {
    flex-wrap: wrap-reverse;
}

/* Common Layout Patterns */
.rlds-flex-row-center {
    flex-direction: row;
    justify-content: center;
    align-items: center;
}

.rlds-flex-column-center {
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.rlds-flex-row-space-between {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
}

.rlds-flex-column-space-between {
    flex-direction: column;
    justify-content: space-between;
    align-items: stretch;
}

.rlds-flex-row-start {
    flex-direction: row;
    justify-content: flex-start;
    align-items: center;
}

.rlds-flex-row-end {
    flex-direction: row;
    justify-content: flex-end;
    align-items: center;
}

.rlds-flex-column-start {
    flex-direction: column;
    justify-content: flex-start;
    align-items: stretch;
}

.rlds-flex-column-end {
    flex-direction: column;
    justify-content: flex-end;
    align-items: stretch;
}

/* Absolute Fill */
.rlds-absolute-fill {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
}

/* ========================================
   SURFACE STYLES
   ======================================== */

.rlds-surface-primary {
    background-color: var(--rlds-surface-primary-background);
}

.rlds-surface-secondary {
    background-color: var(--rlds-surface-secondary-background);
}

/* ========================================
   DIVIDER STYLES
   ======================================== */

.rlds-divider {
    background-color: var(--rlds-border-divider);
    height: 1px;
}

/* ========================================
   RADIO BUTTON STYLES
   ======================================== */

.rlds-radio-group {
    flex-direction: column;
}

.rlds-radio-item {
    flex-direction: column;
    margin-right: var(--rlds-spacing-xs);
    margin-left: var(--rlds-spacing-xs);
    font-size: var(--rlds-font-size-sm);
    color: var(--rlds-text-secondary);
    -unity-font-style: normal;
}

.rlds-radio-item__input-row {
    flex-direction: row;
    align-items: center;
}

.rlds-radio-item RadioButton {
    margin: 0;
    flex-direction: row;
    align-items: center;
}

.rlds-radio-item RadioButton > Label {
    font-size: var(--rlds-font-size-sm);
    color: var(--rlds-text-secondary);
    flex-grow: 1;
    padding-left: var(--rlds-spacing-3xs);
    margin: 0;
}

.rlds-radio-item RadioButton:disabled > Label {
    color: var(--rlds-text-ui-disabled);
}

.rlds-radio-item__selected-indicator {
    position: absolute;
    width: var(--rlds-icon-size-2xs);
    height: var(--rlds-icon-size-2xs);
    border-radius: var(--rlds-radius-full);
    background-color: var(--rlds-icon-ui-selected);
    margin-left: var(--rlds-spacing-xs);
}

.rlds-radio-item__children-container {
    margin-left: var(--rlds-icon-size-lg);
}

.rlds-radio-item__description {
    font-size: var(--rlds-font-size-sm);
    color: var(--rlds-text-secondary);
    margin-bottom: var(--rlds-spacing-xs);
}

.rlds-radio-item__description--disabled {
    color: var(--rlds-text-ui-disabled);
}

/* ========================================
   TOGGLE STYLES
======================================== */

.rlds-toggle Toggle {
    flex-direction: row;
    align-items: center;
}

/* ========================================
   INDICATOR STYLES
   ======================================== */

.rlds-indicator {
    width: var(--rlds-icon-size-2xs);
    height: var(--rlds-icon-size-2xs);
    border-radius: var(--rlds-radius-full);
}

.rlds-indicator--positive {
    background-color: var(--rlds-badge-positive);
}

.rlds-indicator--negative {
    background-color: var(--rlds-badge-negative);
}

.rlds-indicator--warning {
    background-color: var(--rlds-badge-warning);
}

.rlds-indicator--disabled {
    background-color: var(--rlds-badge-disabled);
}

.rlds-indicator--default {
    background-color: var(--rlds-badge-default);
}

.rlds-indicator--privacy {
    background-color: var(--rlds-badge-privacy);
}

/* ========================================
   BADGE STYLES
   ======================================== */

.rlds-badge {
    flex-direction: row;
    align-items: center;
    border-radius: var(--rlds-radius-xs);
    padding: var(--rlds-spacing-4xs) var(--rlds-spacing-xs);
    width: auto;
    height: auto;
}

.rlds-badge__label {
    font-size: var(--rlds-font-size-sm);
    -unity-font-style: bold;
    margin: 0;
    padding: 0;
}

.rlds-badge--positive {
    background-color: var(--rlds-badge-positive);
}

.rlds-badge--positive .rlds-badge__label {
    color: var(--rlds-text-primary);
}

.rlds-badge--negative {
    background-color: var(--rlds-badge-negative);
}

.rlds-badge--negative .rlds-badge__label {
    color: var(--rlds-text-primary);
}

.rlds-badge--warning {
    background-color: var(--rlds-badge-warning);
}

.rlds-badge--warning .rlds-badge__label {
    color: var(--rlds-text-primary);
}

.rlds-badge--disabled {
    background-color: var(--rlds-badge-disabled);
}

.rlds-badge--disabled .rlds-badge__label {
    color: var(--rlds-text-primary);
}

.rlds-badge--default {
    background-color: var(--rlds-badge-default);
}

.rlds-badge--default .rlds-badge__label {
    color: var(--rlds-text-ui-primary);
}

.rlds-badge--privacy {
    background-color: var(--rlds-badge-privacy);
}

.rlds-badge--privacy .rlds-badge__label {
    color: var(--rlds-text-ui-primary);
}

/* ========================================
   PROGRESS BAR STYLES
   ======================================== */

.rlds-progress-bar-container {
    border-radius: var(--rlds-radius-xs);
    height: var(--rlds-spacing-3xs);
    overflow: hidden;
    width: 100%;
    background-color: var(--rlds-progress-bar-empty);
}

.rlds-progress-bar {
    height: 100%;
    background-color: var(--rlds-progress-bar-filled);
    transition-property: inherit;
    transition-duration: 0.25s;
    transition-timing-function: linear;
}

.rlds-progress-bar--error {
    background-color: var(--rlds-progress-bar-error);
}

/* ========================================
   SPINNER STYLES
   ======================================== */

.rlds-spinner-container {
    display: flex;
}

.rlds-spinner {
    border-radius: var(--rlds-radius-full);
    border-width: 2px;
    border-color: rgba(0, 0, 0, 0);
    border-top-color: var(--rlds-progress-ring-foreground-default);
}

/* Size variants */
.rlds-spinner--size-12 {
    width: 12px;
    height: 12px;
}

.rlds-spinner--size-16 {
    width: 16px;
    height: 16px;
}

.rlds-spinner--size-24 {
    width: 24px;
    height: 24px;
}

.rlds-spinner--size-32 {
    width: 32px;
    height: 32px;
}

/* Color variants */
.rlds-spinner--default {
    border-top-color: var(--rlds-progress-ring-foreground-default);
}

.rlds-spinner--accent {
    border-top-color: var(--rlds-progress-ring-foreground-accent);
}

.rlds-spinner--disabled {
    border-top-color: var(--rlds-progress-ring-foreground-disabled);
}

.rlds-spinner--dark {
    border-top-color: var(--rlds-progress-ring-foreground-dark);
}

.rlds-spinner--light {
    border-top-color: var(--rlds-progress-ring-foreground-light);
}

/* ========================================
   RING SPINNER STYLES (Animated)
   ======================================== */

.rlds-ring-spinner-root {
    display: flex;
}

.rlds-ring-spinner {
    border-radius: var(--rlds-radius-full);
    border-width: 2px;
    border-color: var(--rlds-progress-ring-foreground-default) var(--rlds-progress-ring-foreground-default) rgba(0, 0, 0, 0.1) var(--rlds-progress-ring-foreground-default);
}

/* Size variants */
.rlds-ring-spinner--size-12 {
    width: 12px;
    height: 12px;
    border-width: 2px;
}

.rlds-ring-spinner--size-16 {
    width: 16px;
    height: 16px;
    border-width: 3px;
}

.rlds-ring-spinner--size-24 {
    width: 24px;
    height: 24px;
    border-width: 4px;
}

.rlds-ring-spinner--size-32 {
    width: 32px;
    height: 32px;
    border-width: 4px;
}

/* Color variants */
.rlds-ring-spinner--default {
    border-color: var(--rlds-progress-ring-foreground-default) var(--rlds-progress-ring-foreground-default) rgba(0, 0, 0, 0.1) var(--rlds-progress-ring-foreground-default);
}

.rlds-ring-spinner--accent {
    border-color: var(--rlds-progress-ring-foreground-accent) var(--rlds-progress-ring-foreground-accent) rgba(0, 0, 0, 0.1) var(--rlds-progress-ring-foreground-accent);
}

.rlds-ring-spinner--disabled {
    border-color: var(--rlds-progress-ring-foreground-disabled) var(--rlds-progress-ring-foreground-disabled) rgba(0, 0, 0, 0.1) var(--rlds-progress-ring-foreground-disabled);
}

.rlds-ring-spinner--dark {
    border-color: var(--rlds-progress-ring-foreground-dark) var(--rlds-progress-ring-foreground-dark) rgba(0, 0, 0, 0.1) var(--rlds-progress-ring-foreground-dark);
}

.rlds-ring-spinner--light {
    border-color: var(--rlds-progress-ring-foreground-light) var(--rlds-progress-ring-foreground-light) rgba(0, 0, 0, 0.1) var(--rlds-progress-ring-foreground-light);
}

/* ========================================
   TOGGLE STYLES (CONTINUED)
======================================== */

.rlds-toggle Toggle > Label {
    font-size: 14px;
    -unity-font-style: bold;
    color: var(--rlds-text-primary);
    padding-left: var(--rlds-spacing-xs);
    margin: 0;
}

.rlds-toggle Toggle .unity-toggle__input {
    margin: 0;
}

.rlds-toggle Toggle .unity-toggle__checkmark {
    background-color: var(--rlds-surface-secondary-background);
    border-width: var(--rlds-border-width);
    border-color: var(--rlds-border-color-dark);
    border-radius: var(--rlds-radius-xs);
    width: 16px;
    height: 16px;
    margin-right: var(--rlds-spacing-3xs);
}

.rlds-toggle Toggle:hover .unity-toggle__checkmark {
    border-color: rgba(255, 255, 255, 0.2);
}

.rlds-toggle Toggle:checked .unity-toggle__checkmark {
    background-color: var(--rlds-text-link);
    border-color: var(--rlds-text-link);
}

.rlds-toggle Toggle:disabled .unity-toggle__checkmark {
    background-color: var(--rlds-button-disable-background);
    border-color: var(--rlds-border-color-dark);
}

.rlds-toggle Toggle:disabled > Label {
    color: var(--rlds-text-disabled);
}

/* ========================================
   TEXT FIELD STYLES
   ======================================== */

/* Default TextField - Large Size */
.rlds-textfield TextField {
    flex-direction: row;
    align-items: center;
}

.rlds-textfield TextField > Label {
    font-size: var(--rlds-font-size-md);
    -unity-font-style: bold;
    color: var(--rlds-text-primary);
    margin-bottom: var(--rlds-spacing-3xs);
    padding-left: 0;
}

.rlds-textfield TextField .unity-text-field__input {
    background-color: var(--rlds-button-secondary-background-default);
    color: var(--rlds-text-secondary);
    border-width: var(--rlds-border-width);
    border-color: rgba(0, 0, 0, 0);
    border-radius: var(--rlds-radius-xs);
    padding: var(--rlds-spacing-2xs) var(--rlds-spacing-xs);
    font-size: var(--rlds-font-size-md);
    min-height: 24px;
    letter-spacing: 0;
    transition-duration: 0.15s;
    transition-timing-function: ease-out;
    transition-property: inherit;
}

.rlds-textfield TextField .unity-text-field__input:hover {
    background-color: var(--rlds-button-secondary-background-hover);
    border-color: rgba(0, 0, 0, 0);
}

.rlds-textfield TextField .unity-text-field__input:focus {
    border-color: var(--rlds-text-link);
}

.rlds-textfield TextField .unity-text-field__input:disabled {
    background-color: var(--rlds-button-disable-background);
    color: var(--rlds-text-disabled);
    border-color: rgba(0, 0, 0, 0);
}

.rlds-textfield TextField .unity-base-text-field__input--placeholder {
    color: var(--rlds-text-placeholder);
    -unity-font-style: italic;
}

/* Small TextField */
.rlds-textfield-small TextField .unity-text-field__input {
    font-size: var(--rlds-font-size-2xs);
    padding: var(--rlds-spacing-3xs) var(--rlds-spacing-xs);
    min-height: 20px;
}

/* Error State */
.rlds-textfield.error TextField .unity-text-field__input,
.rlds-textfield-error TextField .unity-text-field__input {
    border-color: var(--rlds-text-negative);
}

/* Read-only State */
.rlds-textfield-readonly TextField .unity-text-field__input {
    background-color: var(--rlds-button-secondary-background-default);
    color: var(--rlds-text-secondary);
}

.rlds-textfield-readonly TextField .unity-text-field__input:hover {
    background-color: var(--rlds-button-secondary-background-default);
}

/* TextField with Left Icon */
.rlds-textfield-with-left-icon TextField .unity-text-field__input {
    padding-left: var(--rlds-spacing-xl);
}

/* TextField with Right Icon */
.rlds-textfield-with-right-icon TextField .unity-text-field__input {
    padding-right: var(--rlds-spacing-xl);
}

/* Helper Text Container */
.rlds-textfield__helper-container {
    flex-direction: row;
    justify-content: flex-end;
    margin-top: var(--rlds-spacing-3xs);
    padding-left: 0;
}

.rlds-textfield__helper-container.has-error {
    justify-content: space-between;
}

/* Error Message */
.rlds-textfield__error-message {
    color: var(--rlds-text-negative);
    font-size: var(--rlds-font-size-xs);
}

/* Character Counter */
.rlds-textfield__character-count {
    color: var(--rlds-text-placeholder);
    font-size: var(--rlds-font-size-xs);
}

/* Icon Containers */
.rlds-textfield__icon-left {
    position: absolute;
    left: 6px;
    top: 4px;
    width: var(--rlds-icon-size-sm);
    height: var(--rlds-icon-size-sm);
}

.rlds-textfield__icon-right {
    position: absolute;
    right: 2px;
    top: 6px;
    width: var(--rlds-icon-size-sm);
    height: var(--rlds-icon-size-sm);
}

/* Small Size Icon Adjustments */
.rlds-textfield-small .rlds-textfield__icon-left {
    top: 0;
    width: var(--rlds-icon-size-xs);
    height: var(--rlds-icon-size-xs);
}

.rlds-textfield-small .rlds-textfield__icon-right {
    top: 1px;
    width: var(--rlds-icon-size-xs);
    height: var(--rlds-icon-size-xs);
}

/* Text Area */
.rlds-textfield-textarea TextField .unity-text-field__input {
    min-height: auto;
    white-space: initial;
}

/* Clear Button */
.rlds-textfield__clear-button {
    position: absolute;
    right: 2px;
    top: 6px;
    width: var(--rlds-icon-size-xs);
    height: var(--rlds-icon-size-xs);
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
}

.rlds-textfield-small .rlds-textfield__clear-button {
    top: 4px;
}

/* Password Toggle Button */
.rlds-textfield__password-toggle {
    position: absolute;
    right: 2px;
    top: 4px;
    width: var(--rlds-icon-size-sm);
    height: var(--rlds-icon-size-sm);
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
}

.rlds-textfield-small .rlds-textfield__password-toggle {
    top: 1px;
    width: var(--rlds-icon-size-xs);
    height: var(--rlds-icon-size-xs);
}

/* ========================================
   CODE BLOCK STYLES
   ======================================== */

.rlds-code-block {
    background-color: var(--rlds-surface-secondary-background);
    border-radius: var(--rlds-radius-xs);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.15);
    padding: var(--rlds-spacing-sm) var(--rlds-spacing-md);
    margin-top: var(--rlds-spacing-xs);
    margin-bottom: var(--rlds-spacing-xs);
    overflow: hidden;
}

.rlds-code-block__label {
    font-size: var(--rlds-font-size-md);
    color: var(--rlds-text-secondary);
    white-space: normal;
    -unity-font-style: normal;
    -unity-paragraph-spacing: 16px;
}

.rlds-code-block__language {
    font-size: var(--rlds-font-size-xs);
    color: var(--rlds-text-secondary);
    margin-bottom: var(--rlds-spacing-3xs);
}

/* ========================================
   TOAST STYLES
   ======================================== */

.rlds-toast {
    position: absolute;
    right: var(--rlds-spacing-xs);
    top: var(--rlds-spacing-xs);
    padding: var(--rlds-spacing-3xs) var(--rlds-spacing-xs);
    background-color: rgba(51, 51, 51, 0.9);
    color: rgb(255, 255, 255);
    border-radius: var(--rlds-radius-xs);
    font-size: var(--rlds-font-size-sm);
    display: none;
}

/* ========================================
   ICON BUTTON STYLES
   ======================================== */

.rlds-icon-button {
    width: var(--rlds-icon-size-md);
    height: var(--rlds-icon-size-md);
    min-width: auto;
    padding: var(--rlds-spacing-3xs);
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
    border-radius: var(--rlds-radius-xs);
    opacity: 0.7;
}

.rlds-icon-button:hover {
    background-color: var(--rlds-button-tertiary-background-hover);
}

.rlds-icon-button:active {
    background-color: var(--rlds-button-tertiary-background-pressed);
}

.rlds-icon-button--absolute {
    position: absolute;
    right: var(--rlds-spacing-xs);
    top: var(--rlds-spacing-xs);
    display: none;
}
