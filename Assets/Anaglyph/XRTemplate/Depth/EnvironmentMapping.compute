#include "../Depth/DepthKit.hlsl"
#include "../Depth/EnvMapper.hlsl"

#pragma kernel Clear

[numthreads(4, 4, 4)]
void Clear(uint3 id : SV_DispatchThreadID)
{
	envVolumeRW[id] = 1;
}

#pragma kernel Integrate

Texture2D<float4> envDepthDilated;

[numthreads(64, 1, 1)]
void Integrate(uint id : SV_DispatchThreadID)
{
	float3 vLocalPos = envFrustumVolume[id];
	float3 vWorldPos = mul(agDepthViewInv[0], float4(vLocalPos, 1)).xyz;
	uint3 coord = envWorldToVoxel(vWorldPos);
	float3 voxPos = envVoxelToWorld(coord);

	float3 eyePos = agDepthEyePos();
	float3 eyeRayDir = normalize(voxPos - eyePos);

	float3 voxNDC = agDepthWorldToNDC(voxPos);
	float depthNDC = agDepthSample(voxNDC.xy);

	float3 depthPos = agDepthNDCtoWorld(float3(voxNDC.xy, depthNDC));
	float3 depthNorm = agDepthNormalSample(voxNDC.xy).xyz;

	float voxEyeDist = distance(voxPos, eyePos);
	float depthEyeDist = distance(depthPos, eyePos);
	float normDot = -dot(eyeRayDir, depthNorm);

	float sDist = depthEyeDist - voxEyeDist;
	sDist *= saturate(normDot);

	float sDistNorm = sDist / envVoxDist;
	sDistNorm = min(sDistNorm, 1);

	bool shouldWrite = true;
	float3 voxView = mul(agDepthView[0], float4(voxPos, 1)).xyz;
	float depthDilated = envDepthDilated[voxNDC.xy].x;
	float depthDilatedLinear = agDepthNDCToLinear(depthDilated);
	if (voxView.z > depthDilatedLinear)
		shouldWrite = false;

	// float z = agDepthNDCToLinear(depthNDC);
	// float3 up = mul(agDepthViewInv[0], float4(0, 1, 0, 0)).xyz * envVoxDist;
	// float3 right = mul(agDepthViewInv[0], float4(1, 0, 0, 0)).xyz * envVoxDist;
	//
	// float l = agDepthSampleWorldToLinear(voxPos - right);
	// float lu = agDepthSampleWorldToLinear(voxPos - right + up);
	// float u = agDepthSampleWorldToLinear(voxPos + up);
	// float ru = agDepthSampleWorldToLinear(voxPos + right + up);
	// float r = agDepthSampleWorldToLinear(voxPos + right);
	// float rd = agDepthSampleWorldToLinear(voxPos + right - up);
	// float d = agDepthSampleWorldToLinear(voxPos - up);
	// float ld = agDepthSampleWorldToLinear(voxPos - right - up);
	//
	// bool shouldWrite = !(
	// 	distance(z, l) > envVoxDist ||
	// 	distance(z, lu) > envVoxDist ||
	// 	distance(z, ld) > envVoxDist ||
	// 	distance(z, r) > envVoxDist ||
	// 	distance(z, ru) > envVoxDist ||
	// 	distance(z, rd) > envVoxDist ||
	// 	distance(z, u) > envVoxDist ||
	// 	distance(z, d) > envVoxDist);

	//
	// bool shouldWrite = true;
	// if (sDistNorm == 1.0)
	// {
	// 	// float val = envVolumeRW[coord];
	// 	float3 posBehind = envVoxelToWorld(coord) + eyeRayDir * envVoxSize;
	// 	uint3 voxCoordBehind = envWorldToVoxel(posBehind);
	// 	float valBehind = envVolume[voxCoordBehind];
	//
	// 	if (valBehind < 1.0)
	// 		shouldWrite = false;
	// }

	bool inPlayer = false;
	for (int p = 0; p < envNumPlayers; p++)
	{
		float3 playerPos = envPlayerHeads[p];

		if (distance(vWorldPos.xz, playerPos.xz) < PLAYER_RADIUS &&
			vWorldPos.y < playerPos.y + PLAYER_TOP &&
			vWorldPos.y > playerPos.y - PLAYER_BOTTOM)
		{
			inPlayer = true;
		}
	}

	if (sDistNorm > -1 && !inPlayer && normDot > MIN_DOT && shouldWrite)
		envVolumeRW[coord] = sDistNorm;
}

