#pragma kernel InitDepthDilation

RWTexture2D<float4> dilateSrc;
RWTexture2D<float4> dilateDest;

[numthreads(8, 8, 1)]
void InitDepthDilation(uint2 coord : SV_DispatchThreadID)
{
	float depth = agDepthTex[uint3(coord.xy, 0)];
	dilateSrc[coord] = float4(depth, coord.xy, 0);
	dilateDest[coord] = float4(1.0, 0, 0, 0);
}

#pragma kernel DilateDepthStep

int dilateStepSize = 512;

void Pull(uint2 destCoord, int2 jump)
{
	// jump from source to target

	uint2 srcCoord = destCoord + jump;

	srcCoord = clamp(srcCoord, uint2(0, 0), agDepthTexSize);

	float4 srcVal = dilateSrc[srcCoord];

	float4 destVal = dilateDest[destCoord];

	float srcDepth = srcVal.x;

	if (srcDepth == 0)
		return;

	float destDepth = destVal.x;

	// uint2 srcOriginCoord = srcVal.yz;

	// float z = agDepthNDCToLinear(srcDepth);
	// float4x4 proj = agDepthProj[0];
	//
	// float2 focalLengths = float2(proj._m00, proj._m11);
	// float2 pixelSize = 2.0 * abs(z) / (focalLengths * agDepthTexSize);
	//
	// float dilateRadius = 64; //envVoxDist / pixelSize.x;
	//
	// if (distance(srcOriginCoord.xy, destCoord.xy) > dilateRadius)
	// 	return;

	if (srcDepth > destDepth)
		return;

	dilateDest[destCoord] = srcVal;
}

[numthreads(8, 8, 1)]
void DilateDepthStep(uint2 coord : SV_DispatchThreadID)
{
	int s = dilateStepSize;

	Pull(coord, int2(s, 0));
	Pull(coord, int2(s, s));
	Pull(coord, int2(0, s));
	Pull(coord, int2(-s, s));
	Pull(coord, int2(-s, 0));
	Pull(coord, int2(-s, -s));
	Pull(coord, int2(0, -s));
	Pull(coord, int2(s, -s));
}

