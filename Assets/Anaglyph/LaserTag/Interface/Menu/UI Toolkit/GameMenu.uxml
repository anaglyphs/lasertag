			<ui:Instance name="home-page" template="GameHomePage" class="nav-page" />
			<ui:Instance name="match-page" template="GameMatchPage" class="nav-page" />
			<ui:Instance name="map-manager-page" template="GameMapManagerPage" class="nav-page" />
