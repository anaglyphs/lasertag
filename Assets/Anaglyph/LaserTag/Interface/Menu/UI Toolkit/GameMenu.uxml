<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
	<Style src="LaserTagMenu.uss" />
	<ui:Template name="GameHomePage" src="Pages/GameHomePage.uxml" />
	<ui:Template name="GameMatchPage" src="Pages/GameMatchPage.uxml" />
	<ui:Template name="GameMapManagerPage" src="Pages/GameMapManagerPage.uxml" />
	<ui:Template name="GamePlayingPage" src="Pages/GamePlayingPage.uxml" />
	<ui:Template name="GameEditingMapPage" src="Pages/GameEditingMapPage.uxml" />
	<ui:VisualElement class="menu-root" picking-mode="Ignore">
